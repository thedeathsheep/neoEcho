# === Echo Environment Configuration ===

# Runtime environment
NODE_ENV=development

# AI Provider: openai | anthropic | deepseek
AI_PROVIDER=openai

# Your API Key (BYOK - Bring Your Own Key)
AI_API_KEY=

# Model name (e.g., gpt-4o, claude-sonnet-4-20250514, deepseek-chat)
AI_MODEL=gpt-4o

# Custom API base URL (for DeepSeek or proxy)
# AI_BASE_URL=https://api.deepseek.com/v1

# Generation parameters
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2048

# App
NEXT_PUBLIC_APP_NAME=Echo
